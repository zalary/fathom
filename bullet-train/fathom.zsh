# Fathom — Bullet Train color theme
#
# Source this file before or after your bullet-train config.
# Terminal must be using the Fathom palette (Ghostty or equivalent).
#
# Palette reference (mapped to terminal colors 0-7):
#   black   #4D5355   blue    #7A8280
#   red     #949B79   magenta #999999
#   green   #88908E   cyan    #AAAAAA
#   yellow  #99926B   white   #C0C0C0

# Context (user@host)
BULLETTRAIN_CONTEXT_BG=black
BULLETTRAIN_CONTEXT_FG=cyan

# Directory
BULLETTRAIN_DIR_BG=blue
BULLETTRAIN_DIR_FG=white

# Git — clean
BULLETTRAIN_GIT_BG=green
BULLETTRAIN_GIT_FG=black
# Git — dirty / untracked
BULLETTRAIN_GIT_DIRTY_BG=yellow
BULLETTRAIN_GIT_DIRTY_FG=black
BULLETTRAIN_GIT_DIRTY="✘"
BULLETTRAIN_GIT_CLEAN="✔"

# NVM
BULLETTRAIN_NVM_BG=magenta
BULLETTRAIN_NVM_FG=black

# Command execution time
BULLETTRAIN_EXEC_TIME_BG=black
BULLETTRAIN_EXEC_TIME_FG=yellow

# Exit status
BULLETTRAIN_STATUS_EXIT_SHOW=true
BULLETTRAIN_STATUS_BG=black
BULLETTRAIN_STATUS_ERROR_BG=red
BULLETTRAIN_STATUS_FG=white
